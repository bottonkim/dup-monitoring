# ============================================================
# 서울시 지구단위계획 조회·모니터링 시스템 - 설정 템플릿
# 이 파일을 .env 로 복사한 뒤 값을 채워주세요
# ============================================================

# --- 주소 API (juso.go.kr) ---
# 등록: https://www.juso.go.kr/addrlink/devAddrLinkRequestScopeNew.do
JUSO_API_KEY=your_juso_api_key_here

# --- VWORLD (국가공간정보오픈플랫폼) ---
# 등록: https://www.vworld.kr/dev/v4dv_authguide_s001.do
VWORLD_API_KEY=your_vworld_api_key_here

# --- 서울 열린데이터광장 ---
# 등록: https://data.seoul.go.kr/together/guide/useGuide.do
SEOUL_API_KEY=your_seoul_openapi_key_here

# --- Anthropic Claude API ---
# 등록: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# --- 이메일 (SMTP) ---
# Gmail 사용 시: 2단계 인증 후 앱 비밀번호 발급 필요
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=서울 도시계획 모니터 <your_email@gmail.com>
# 여러 수신자는 쉼표로 구분
EMAIL_TO=recipient@example.com

# --- 스케줄 ---
# 스크래퍼 실행 주기 (cron 형식, 기본: 6시간마다)
SCHEDULE_SCRAPER_CRON=0 */6 * * *
# 일일 다이제스트 이메일 발송 시각 (KST, HH:MM)
SCHEDULE_DIGEST_TIME=09:00
# 결정고시 즉시 알림 체크 주기 (분)
SCHEDULE_ALERT_INTERVAL_MINUTES=240

# --- 경로 ---
DB_PATH=data/db/monitoring.db
PDF_CACHE_DIR=data/pdfs
LOG_FILE=logs/app.log
LOG_LEVEL=INFO

# --- 스크래핑 동작 ---
# 소스별 최대 스크래핑 페이지 수
MAX_PAGES_PER_SOURCE=5
# 요청 타임아웃 (초)
REQUEST_TIMEOUT=30
# 재시도 횟수
MAX_RETRY_ATTEMPTS=3
# 재시도 대기 시간 (초, 지수 기반)
RETRY_BACKOFF_SECONDS=5
# 고시공고 조회 기준 일수 (오늘로부터 N일 이전)
LOOKBACK_DAYS=30

# --- PDF 처리 ---
# 다운로드 최대 크기 (MB)
MAX_PDF_SIZE_MB=50
# Claude API 에 전송할 최대 텍스트 글자 수
CLAUDE_MAX_PDF_CHARS=100000
